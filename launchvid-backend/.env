# ─── Paste your keys below ────────────────────────────────────────────────────

# Gemini (free) → https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Groq (free) → https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Supabase → https://supabase.com → project → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here

# ─── Optional (leave as-is for local dev) ─────────────────────────────────────

# Where rendered videos are temporarily stored
OUTPUT_DIR=/tmp/launchvid_outputs

# Remotion renderer directory (relative to backend root)
REMOTION_DIR=../launchvid-remotion

# Port for FastAPI
PORT=8000